{
  "version": "2",
  "templates": [
    {
      "type": 1,
      "title": "SQL Server 2017-custom",
      "description": "Microsoft SQL Server 2017 (custom data-path) on Linux",
      "categories": [
        "Database"
      ],
      "platform": "linux",
      "note": "Password needs to include at least 8 characters including uppercase, lowercase letters, base-10 digits and/or non-alphanumeric symbols.",
      "logo": "https://portainer-io-assets.sfo2.digitaloceanspaces.com/logos/microsoft.png",
      "image": "mcr.microsoft.com/mssql/server:2017-latest",
      "ports": [
        "[[HOST_PORT]]:1433/tcp"
      ],
      "env": [
        {
          "name": "ACCEPT_EULA",
          "default": "Y",
          "preset": true
        },
        {
          "name": "SA_PASSWORD",
          "label": "SA password"
        },
        {
          "name": "HOST_PORT",
          "label": "Host port",
          "default": "1433"
        },
        {
          "name": "DATA_FOLDER",
          "label": "Data folder",
          "default": "/srv"
        }
      ],
      "volumes": [
        {
          "container": "/var/opt/mssql",
          "bind": "[[DATA_FOLDER]]"
        }
      ]
    }
  ]
}